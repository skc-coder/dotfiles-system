	<unique-id>16885376510008</unique-id>
	<name>Resize Images</name>
	<submenu>Sentry Tools</submenu>
	<icon>zoom-fit-best</icon>
	<command>/home/skc/.local/bin/image_tools.sh resize %F</command>
	<description>Change resolution of selected images</description>
	<patterns>*.png;*.jpg;*.jpeg;*.webp;*.bmp;*.gif</patterns>
	<image-files/>
</action>
<action>
	<unique-id>16885376510009</unique-id>
	<name>Compress Images</name>
	<submenu>Sentry Tools</submenu>
	<icon>document-properties</icon>
	<command>/home/skc/.local/bin/image_tools.sh compress %F</command>
	<description>Reduce image file size</description>
	<patterns>*.png;*.jpg;*.jpeg;*.webp;*.bmp;*.gif</patterns>
	<image-files/>
</action>
<action>
	<unique-id>16885376510010</unique-id>
	<name>Extract Archive Here</name>
	<submenu>Sentry Tools</submenu>
	<icon>package-x-generic</icon>
	<command>/home/skc/.local/bin/archive_tools.sh extract %F</command>
	<description>Decompress archive here</description>
	<patterns>*.zip;*.tar;*.gz;*.tgz;*.xz;*.txz;*.bz2;*.tbz2;*.7z;*.rar</patterns>
	<other-files/>
</action>
<action>
	<unique-id>16885376510011</unique-id>
	<name>Create Archive...</name>
	<submenu>Sentry Tools</submenu>
	<icon>package-x-generic</icon>
	<command>/home/skc/.local/bin/archive_tools.sh create %F</command>
	<description>Compress selected files</description>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
