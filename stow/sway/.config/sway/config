###========================
# Minimal Sway Config
# Fedora + Waybar + Rofi
###========================
output eDP-1 scale 1

### Variables
set $mod Mod4
set $alt Mod1

set $left h
set $down j
set $up k
set $right l

set $term kitty
set $menu rofi -show drun
set $web brave-browser
set $explorer thunar

### Appearance (minimal + modern)
output * bg /home/skc/.config/sway/current_wallpaper fill

gaps inner 8
gaps outer 4
smart_gaps on

default_border pixel 2
default_floating_border pixel 2

### Colors (Nord-ish)
client.focused          #88c0d0 #88c0d0 #2e3440 #88c0d0 #88c0d0
client.unfocused        #3b4252 #3b4252 #d8dee9 #3b4252 #3b4252
client.urgent           #bf616a #bf616a #eceff4 #bf616a #bf616a

### Startup apps
exec /usr/libexec/lxqt-policykit-agent
exec mako
exec nm-applet --indicator
exec blueman-applet
# exec waybar
exec gammastep
exec_always sh -c 'echo 1 | sudo tee /sys/devices/platform/asus-nb-wmi/fan_boost_mode > /dev/null && echo 1 > /tmp/fan_mode_state'
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway GTK_THEME=Mint-Y-Dark
exec systemctl --user start sway-session.target
exec copyq
exec thunar --daemon
exec ~/.local/bin/wallpaper-scheduler.sh

exec swayidle -w \
    timeout 900 'swaylock -f' \
    timeout 1200 'systemctl suspend' \
    before-sleep 'swaylock -f'

### Input
input type:keyboard {
    xkb_layout us
    xkb_numlock enable
}

