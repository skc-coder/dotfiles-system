### ========================
### KEYBINDINGS
### ========================

## Terminal / launcher
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+space exec $menu
bindsym $mod+v exec copyq toggle
## Apps
bindsym $mod+b exec $web 
bindsym $mod+e exec $explorer 

## Lock / exit / reload
bindsym $mod+Shift+BackSpace exec swaylock -f
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m "Exit Sway?" -B "Yes" "swaymsg exit"
bindsym $mod+q kill

## Focus movement (hjkl)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

## Arrow keys (Mod)
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

## Arrow keys (Alt)
bindsym $alt+Left focus left
bindsym $alt+Right focus right
bindsym $alt+Up focus up
bindsym $alt+Down focus down

## Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

## Layout
bindsym $mod+f fullscreen
bindsym $mod+s layout toggle split
bindsym $mod+t layout tabbed
bindsym $mod+Shift+space floating toggle
bindsym $mod+BackSpace split toggle

## Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

## Scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+Shift+minus move scratchpad

## Resize mode
mode "resize" {
    bindsym h resize shrink width 40 px
    bindsym j resize grow height 40 px
    bindsym k resize shrink height 40 px
    bindsym l resize grow width 40 px

    bindsym Left resize shrink width 40 px
    bindsym Right resize grow width 40 px
    bindsym Up resize shrink height 40 px
    bindsym Down resize grow height 40 px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

### Mouse
floating_modifier $mod normal

### Bar
bar {
    swaybar_command waybar
}

# Sentry / Dotfiles Shortcuts
bindsym Mod4+Shift+o exec /home/skc/dev/dotfiles/scripts/ocr_screenshot.sh
bindsym Print exec env QT_QPA_PLATFORM=wayland QT_AUTO_SCREEN_SCALE_FACTOR=0 QT_SCALE_FACTOR=1 flameshot gui
for_window [app_id="flameshot"] border pixel 0, floating enable, fullscreen disable, move absolute position 0 0
# Toggle VPN off if running, or open menu to choose location if disconnected
bindsym Mod4+Shift+V exec ~/.local/bin/vpn-toggle.sh
# Select wallpaper via Rofi menu
bindsym Mod4+Shift+W exec ~/.local/bin/wallpaper-selector.sh

# CopyQ floating rule
for_window [app_id="copyq"] floating enable
for_window [class="copyq"] floating enable

# Global Dark Mode
exec_always gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
exec_always gsettings set org.gnome.desktop.interface gtk-theme 'Mint-Y-Dark'

# MEGAsync startup and rules
for_window [app_id="(?i)megasync"] floating enable, move scratchpad
for_window [class="(?i)megasync"] floating enable, move scratchpad
exec ~/.local/bin/megasync

# Thunderbird startup and rules
for_window [app_id="(?i)thunderbird"] floating enable, move scratchpad
for_window [class="(?i)thunderbird"] floating enable, move scratchpad
exec ~/.local/bin/thunderbird

