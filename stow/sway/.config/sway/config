### ========================
### FUNCTION / FN KEYS
### ========================
bindsym $mod+F5 exec /home/skc/dev/dotfiles/scripts/fan-toggle.sh
## Audio
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

## Media
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl position 20+
bindsym XF86AudioPrev exec playerctl position 20-

## Brightness
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

## Keyboard backlight
bindsym XF86KbdBrightnessUp exec brightnessctl -d '::kbd_backlight' set +10%
bindsym XF86KbdBrightnessDown exec brightnessctl -d '::kbd_backlight' set 10%-

## Screen / lock
# XF86ScreenSaver बटन से स्क्रीन को ऑन/ऑफ (Toggle) करें
bindsym XF86ScreenSaver exec brightnessctl set 0% --save || brightnessctl set 50% --restore

## Sleep
bindsym XF86Sleep exec systemctl suspend

## WiFi toggle
bindsym XF86RFKill exec nmcli radio wifi toggle

## screen saver
# XF86ScreenSaver बटन से स्क्रीन को ऑन/ऑफ (Toggle) करें

## Touchpad toggle
# ELAN1200 टचपैड को ऑन/ऑफ करने के लिए शॉर्टकट
bindsym $mod+F10 input "1267:12432:ELAN1200:00_04F3:3090_Touchpad" events toggle enabled disabled

# bindsym XF86TouchpadToggle input type:touchpad events toggle enabled disabled


