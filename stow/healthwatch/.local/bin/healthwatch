#!/usr/bin/env python3
import os
import sys
import json
import time
import subprocess
import argparse
from datetime import datetime

CONFIG_DIR = os.path.expanduser("~/.config/healthwatch")
CONFIG_PATH = os.path.join(CONFIG_DIR, "config.json")
STATE_PATH = os.path.join(CONFIG_DIR, "state.json")

DEFAULT_CONFIG = {
    "eye_interval_minutes": 20,
    "exercise_interval_minutes": 50,
    "eye_sound_path": "/home/skc/dev/dotfiles/system/eye_rest.mp3",
    "exercise_sound_path": "/home/skc/dev/dotfiles/system/exercise.mp3"
}

def load_json(path, default):
    if not os.path.exists(path):
        return default
    try:
        with open(path, "r") as f:
            return json.load(f)
    except Exception:
        return default

def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        json.dump(data, f, indent=4)

def play_sound(sound_path):
    if not sound_path or not os.path.exists(sound_path):
        return
    try:
        # Run mpv to play sound in background/non-blocking or blocking depending on flow.
        # Since notifications are quick, we can run it asynchronously so it doesn't block the loop.
        subprocess.Popen([
            "mpv",
            "--no-video",
            sound_path
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print(f"Error playing sound {sound_path}: {e}", file=sys.stderr)

def send_notification(summary, body, icon="dialog-information", sound_path=None):
    try:
        subprocess.run([
            "notify-send",
            "-a", "HealthWatch",
            "-i", icon,
            summary,
            body
        ], check=True)
    except Exception as e:
        print(f"Error sending notification: {e}", file=sys.stderr)
    
    if sound_path:
        play_sound(sound_path)

def get_remaining_time_str(seconds):
    if seconds <= 0:
        return "Now"
    mins, secs = divmod(int(seconds), 60)
    if mins > 0:
        return f"{mins}m {secs}s"
    return f"{secs}s"

def run_daemon():
    print("HealthWatch daemon started.")
    
    # Save PID so user can identify running instance if needed
    save_json(STATE_PATH, {
        "pid": os.getpid(),
        "last_eye_time": time.time(),
        "last_exercise_time": time.time()
    })
    
    config = load_json(CONFIG_PATH, DEFAULT_CONFIG)
    last_config_mtime = os.path.getmtime(CONFIG_PATH) if os.path.exists(CONFIG_PATH) else 0
    
    state = load_json(STATE_PATH, {})
    last_eye = state.get("last_eye_time", time.time())
    last_exercise = state.get("last_exercise_time", time.time())
    
    # Immediate notification on startup to confirm daemon runs
    send_notification(
        "HealthWatch Active",
        f"Monitoring started. Eye rest: {config['eye_interval_minutes']}m | Exercise: {config['exercise_interval_minutes']}m",
        "appointment-reminder"
    )

    while True:
        # Check if config file was updated
        if os.path.exists(CONFIG_PATH):
            mtime = os.path.getmtime(CONFIG_PATH)
            if mtime > last_config_mtime:
                config = load_json(CONFIG_PATH, DEFAULT_CONFIG)
                last_config_mtime = mtime
                print(f"Config reloaded: {config}")
        
        current_time = time.time()
        eye_interval = config.get("eye_interval_minutes", 20) * 60
        exercise_interval = config.get("exercise_interval_minutes", 50) * 60
        
        # Check Eye rest timer
        if current_time - last_eye >= eye_interval:
            send_notification(
                "👀 Rest Your Eyes",
                "Look away from the screen! Focus on an object 20 feet away for 20 seconds.",
                "preferences-desktop-screensaver",
                sound_path=config.get("eye_sound_path")
            )
            last_eye = current_time
            
        # Check Exercise timer
        if current_time - last_exercise >= exercise_interval:
            send_notification(
                "🏃 Quick Exercise Time",
                "Time to stand up, stretch, or do a quick 2-minute exercise/walk!",
                "system-run",
                sound_path=config.get("exercise_sound_path")
            )
            last_exercise = current_time
            
        # Update state file periodically so CLI --status is accurate
        save_json(STATE_PATH, {
            "pid": os.getpid(),
            "last_eye_time": last_eye,
            "last_exercise_time": last_exercise
        })
        
        time.sleep(10)

def main():
    parser = argparse.ArgumentParser(description="HealthWatch - Background Eye & Exercise Notification System")
    parser.add_argument("--daemon", action="store_true", help="Run the background daemon")
    parser.add_argument("--status", action="store_true", help="Show current status and remaining time")
    parser.add_argument("--set-eye", type=int, metavar="MINUTES", help="Set the eye rest interval in minutes")
    parser.add_argument("--set-exercise", type=int, metavar="MINUTES", help="Set the exercise interval in minutes")
    parser.add_argument("--test-eye", action="store_true", help="Send a test eye notification immediately")
    parser.add_argument("--test-exercise", action="store_true", help="Send a test exercise notification immediately")
    
    args = parser.parse_args()
    
    # Ensure config directory exists
    os.makedirs(CONFIG_DIR, exist_ok=True)
    
    if args.daemon:
        run_daemon()
        return

    # Handle config changes
    if args.set_eye is not None or args.set_exercise is not None:
        config = load_json(CONFIG_PATH, DEFAULT_CONFIG)
        if args.set_eye is not None:
            if args.set_eye <= 0:
                print("Interval must be positive.")
                sys.exit(1)
            config["eye_interval_minutes"] = args.set_eye
            print(f"Eye rest interval set to {args.set_eye} minutes.")
        if args.set_exercise is not None:
            if args.set_exercise <= 0:
                print("Interval must be positive.")
                sys.exit(1)
            config["exercise_interval_minutes"] = args.set_exercise
            print(f"Exercise interval set to {args.set_exercise} minutes.")
        save_json(CONFIG_PATH, config)
        return

    # Handle manual notification tests
    if args.test_eye:
        config = load_json(CONFIG_PATH, DEFAULT_CONFIG)
        send_notification("👀 Test: Rest Your Eyes", "This is a test notification for resting your eyes.", "preferences-desktop-screensaver", sound_path=config.get("eye_sound_path"))
        return
    if args.test_exercise:
        config = load_json(CONFIG_PATH, DEFAULT_CONFIG)
        send_notification("🏃 Test: Quick Exercise", "This is a test notification for a quick exercise.", "system-run", sound_path=config.get("exercise_sound_path"))
        return

    # Handle status check
    if args.status:
        config = load_json(CONFIG_PATH, DEFAULT_CONFIG)
        state = load_json(STATE_PATH, {})
        
        print("=== HealthWatch Status ===")
        print(f"Configuration File: {CONFIG_PATH}")
        print(f"Eye Rest Interval:  {config.get('eye_interval_minutes')} minutes")
        print(f"Exercise Interval:  {config.get('exercise_interval_minutes')} minutes")
        print(f"Eye Sound Path:     {config.get('eye_sound_path')}")
        print(f"Exercise Sound Path: {config.get('exercise_sound_path')}")
        
        pid = state.get("pid")
        if pid:
            # Check if PID is actually running
            is_running = False
            try:
                os.kill(pid, 0)
                is_running = True
            except OSError:
                pass
            
            print(f"Daemon Status:      {'RUNNING (PID ' + str(pid) + ')' if is_running else 'NOT RUNNING (Stopped or stale PID)'}")
            
            if is_running:
                current_time = time.time()
                last_eye = state.get("last_eye_time", current_time)
                last_exercise = state.get("last_exercise_time", current_time)
                
                next_eye_sec = (last_eye + config.get("eye_interval_minutes") * 60) - current_time
                next_exercise_sec = (last_exercise + config.get("exercise_interval_minutes") * 60) - current_time
                
                print(f"Next Eye Rest:      in {get_remaining_time_str(next_eye_sec)}")
                print(f"Next Exercise:      in {get_remaining_time_str(next_exercise_sec)}")
        else:
            print("Daemon Status:      NOT RUNNING (No state file found)")
        return
        
    parser.print_help()

if __name__ == "__main__":
    main()
